# Profile: local | openai
# - local  -> por defecto usa LM Studio y base RAG local
# - openai -> por defecto usa OpenAI y base RAG separada
RAG_PROFILE=local

# Provider: lmstudio | openai
# Si no defines RAG_LLM_PROVIDER, se toma segun RAG_PROFILE.
RAG_LLM_PROVIDER=lmstudio

# Rutas de almacenamiento RAG (puedes sobreescribirlas si quieres):
# - local  -> data/rag_local.db + data/chroma_local
# - openai -> data/rag_openai.db + data/chroma_openai
# RAG_SQLITE_PATH=./data/rag_local.db
# RAG_CHROMA_DIR=./data/chroma_local

# Modelos (si no defines, tambien se toman segun RAG_PROFILE)
RAG_CHAT_MODEL=qwen/qwen3-4b-thinking-2507
RAG_TEMPERATURE=0.1
RAG_EMBEDDING_MODEL=text-embedding-nomic-embed-code

# LM Studio config
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio

# OpenAI API config
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
